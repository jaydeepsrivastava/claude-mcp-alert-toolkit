# ══════════════════════════════════════════════════════════════════════════════
# Claude MCP Servers — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── IR Logs MCP (mcp-servers/ir-logs) ────────────────────────────────────────

# Path to your inventory.json (host/site map)
INVENTORY_PATH=/home/<YOUR_WSL_USER>/jaydeep_claude/inventory.json

# SSH user for all IR hosts (standard across all sites)
IR_SSH_USER=contactual

# Path to your ed25519 private key (must be in contactual's authorized_keys on each host)
IR_SSH_KEY=/home/<YOUR_WSL_USER>/.ssh/id_ed25519

# Optional: log file path override (default shown below — do not change unless non-standard)
# IR_LOG_PATH=/var/log/contactual/p-ir.0.log

# Optional: bastion/jump host for sites not directly reachable
# IR_JUMP_HOST=bastion.yourdomain.net
# IR_JUMP_USER=contactual

# Optional: max parallel SSH connections per query (default: 10)
# IR_CONCURRENCY=10

# ── DevOps Assistant MCP (mcp-devops-demo) ───────────────────────────────────

# PagerDuty REST API key (read-only token is sufficient for incident lookups)
PAGERDUTY_API_KEY=

# CheckMK automation user credentials
CHECKMK_USER=
CHECKMK_SECRET=

# CheckMK base URL  e.g. https://checkmk.yourdomain.net/prod
CHECKMK_BASE_URL=
